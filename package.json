{
  "name": "@evgkch/channeljs",
  "version": "1.0.0",
  "description": "A lib to create a channel to send and receive messages",
  "type": "module",
  "sideEffects": false,
  "files": ["dist"],
  "publishConfig": {
    "access": "public"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "NODE_OPTIONS=--experimental-vm-modules jest",
    "prepublishOnly": "npm run build && npm test"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/evgkch/channeljs.git"
  },
  "keywords": [
    "channel",
    "emitter",
    "receiver",
    "transmitter",
    "messages"
  ],
  "author": "Evgeny Kucherenko",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/evgkch/channeljs/issues"
  },
  "homepage": "https://github.com/evgkch/channeljs#readme",
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "jest": "^30.4.2",
    "ts-jest": "^29.4.11",
    "typescript": "^6.0.3"
  }
}
